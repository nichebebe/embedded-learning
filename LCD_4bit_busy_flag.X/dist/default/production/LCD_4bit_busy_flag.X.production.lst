  1342                           ;Config register CONFIG1 @ 0x8007
  1343                           ;	Oscillator Selection
  1344                           ;	FOSC = INTOSC, INTOSC oscillator: I/O function on CLKIN pin
  1345                           ;	Watchdog Timer Enable
  1346                           ;	WDTE = OFF, WDT disabled
  1347                           ;	Power-up Timer Enable
  1348                           ;	PWRTE = OFF, PWRT disabled
  1349                           ;	MCLR Pin Function Select
  1350                           ;	MCLRE = OFF, MCLR/VPP pin function is digital input
  1351                           ;	Flash Program Memory Code Protection
  1352                           ;	CP = OFF, Program memory code protection is disabled
  1353                           ;	Data Memory Code Protection
  1354                           ;	CPD = 0x1, unprogrammed default
